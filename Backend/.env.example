# 
# CONFIGURAÇÃO DE BANCO DE DADOS
# 
# URL de conexão com o banco de dados MySQL
# Formato: jdbc:mysql://host:porta/nome_banco?useSSL=false&serverTimezone=UTC<br/>
DB_URL=jdbc:mysql://localhost:3306/crm_versatilis?useSSL=false&serverTimezone=UTC

# Usuário do banco de dados
# NUNCA use 'root' em produção. Crie um usuário dedicado.
DB_USERNAME=crm_user

# Senha do banco de dados
# Use uma senha forte com letras, números e caracteres especiais. Mínimo 12 caracteres.
DB_PASSWORD=SenhaForte123!@#

# 
# CONFIGURAÇÃO JWT
# 
# Chave secreta para assinar tokens JWT
# CRÍTICO: Use uma chave forte e aleatória. Mínimo 256 bits (32 caracteres em base64).
# Para HS512, recomenda-se uma chave com pelo menos 64 caracteres.
# Gere com: openssl rand -base64 64
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_com_minimo_256_bits_e_mais_de_32_caracteres_para_HS512

# Tempo de expiração do token em milissegundos
# 86400000 = 24 horas
JWT_EXPIRATION=86400000

# 
# CONFIGURAÇÃO DE AMBIENTE
# 
# Ambiente da aplicação: development, staging, production
APP_ENVIRONMENT=development

# Modo debug: true ou false
# NUNCA ative em produção.
APP_DEBUG=false

# 
# HIBERNATE
# 
# Estratégia de DDL: create, create-drop, update, validate<br/>
# - create: cria tabelas (apaga dados existentes)<br/>
# - create-drop: cria e apaga ao encerrar<br/>
# - update: atualiza schema existente<br/>
# - validate: apenas valida (recomendado em produção)
HIBERNATE_DDL_AUTO=update